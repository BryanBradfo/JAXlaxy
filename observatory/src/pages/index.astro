---
import Base from "../layouts/Base.astro";
import Galaxy from "../components/Galaxy.tsx";
---

<Base>
  <main class="relative min-h-screen">
    <header
      class="absolute top-0 left-0 right-0 z-10 px-6 py-5 flex items-baseline justify-between"
    >
      <h1 class="text-2xl font-semibold tracking-tight">
        <span style="color: var(--color-cyan-neon)">JAXlaxy</span>
        <span class="text-white/70"> Observatory</span>
      </h1>
      <nav class="flex gap-6 text-sm">
        <a href="/" class="text-white/90 hover:text-[color:var(--color-cyan-neon)] transition">Map</a>
        <a
          href="/table"
          class="text-white/60 hover:text-[color:var(--color-cyan-neon)] transition">Data Table</a
        >
        <a
          href="https://github.com/BryanBradfo/JAXlaxy"
          class="text-white/60 hover:text-[color:var(--color-cyan-neon)] transition"
          >GitHub&nbsp;↗</a
        >
      </nav>
    </header>

    <div class="absolute inset-0">
      <Galaxy client:load />
    </div>

    <div
      class="absolute bottom-6 left-6 max-w-md text-xs text-white/50 leading-relaxed z-10 pointer-events-none"
    >
      <p>
        Each glowing star is an entry from JAXlaxy's README. Size is proportional to GitHub stars; color indicates health
        (🟢 active · 🟡 stable · 🔴 legacy). Drag to orbit.
      </p>
    </div>
  </main>
</Base>
