---
import Base from "../layouts/Base.astro";
---

<Base title="Data Table — JAXlaxy Observatory">
  <main class="min-h-screen px-6 py-16 max-w-4xl mx-auto">
    <header class="mb-8">
      <h1 class="text-3xl font-semibold tracking-tight mb-2">
        <span style="color: var(--color-cyan-neon)">Data Table</span>
      </h1>
      <p class="text-white/60">
        Phase 1 stub — a sortable, filterable scannable table view is coming in a follow-up.
      </p>
    </header>
    <nav class="text-sm">
      <a href="/" class="text-[color:var(--color-cyan-neon)] hover:underline">
        ← Back to the Galaxy Map
      </a>
    </nav>
  </main>
</Base>
