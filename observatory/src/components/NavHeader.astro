---
interface Props {
  active?: "map" | "table";
  class?: string;
}

const { active = "map", class: className = "" } = Astro.props;

const mapActive = active === "map";
const tableActive = active === "table";
---

<header
  class:list={[
    "px-6 py-5 flex items-baseline justify-between",
    className,
  ]}
>
  <a
    href="/"
    class="text-2xl font-semibold tracking-tight hover:opacity-90 transition"
  >
    <span style="color: var(--color-cyan-neon)">JAXlaxy</span>
    <span class="text-white/70"> Observatory</span>
  </a>
  <nav class="flex gap-6 text-sm">
    <a
      href="/"
      class:list={[
        "transition",
        mapActive
          ? "text-[color:var(--color-cyan-neon)]"
          : "text-white/60 hover:text-[color:var(--color-cyan-neon)]",
      ]}
    >
      Map
    </a>
    <a
      href="/table"
      class:list={[
        "transition",
        tableActive
          ? "text-[color:var(--color-cyan-neon)]"
          : "text-white/60 hover:text-[color:var(--color-cyan-neon)]",
      ]}
    >
      Data Table
    </a>
    <a
      href="https://github.com/BryanBradfo/JAXlaxy"
      class="text-white/60 hover:text-[color:var(--color-cyan-neon)] transition"
    >
      GitHub&nbsp;↗
    </a>
  </nav>
</header>
