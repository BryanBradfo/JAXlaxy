---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "JAXlaxy Observatory",
  description = "Interactive 3D map of the JAX ecosystem — 75 libraries as glowing stars, sized by GitHub stars, colored by health, auto-refreshed every Monday.",
} = Astro.props;

// Route favicon (and other public/ assets referenced from this layout)
// through BASE_URL so they resolve under the production sub-path.
const base = import.meta.env.BASE_URL;

// Absolute URLs are required by OG / Twitter card scrapers — they fetch
// the meta-image from outside the site, so a relative path like
// "/og-image.png" wouldn't resolve. `Astro.site` is the canonical origin
// from astro.config.mjs (https://jaxlaxy.bryanbradfo.me).
const ogImage = new URL(`${base}og-image.png`, Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}favicon.png`} />

    {/* OpenGraph — Facebook, LinkedIn, Slack, Discord, generic crawlers */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="JAXlaxy Observatory" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="3D galaxy map of the JAX ecosystem" />

    {/* Twitter / X card — uses summary_large_image so the preview shows the
        full image at 1200×630 instead of a thumbnail. */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="3D galaxy map of the JAX ecosystem" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
